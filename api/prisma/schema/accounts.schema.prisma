model Accounts {
  id                       String                     @id @default(uuid())
  email                    String                     @unique
  password                 String
  username                 String
  created_at               DateTime                   @default(now())
  updated_at               DateTime                   @updatedAt
  refresh_token            String?                    @unique
  user_profile             User_Profile?
  member_profiles_comities Member_Profiles_Comities[]

  @@map("accounts")
}

model Accounts_Otp {
  id         String    @id @default(uuid())
  otp_code   Int
  email      String
  used_at    DateTime?
  expires_at DateTime  @updatedAt
  created_at DateTime  @default(now())
  is_used    Boolean   @default(false)

  @@map("accounts_otp")
}

model User_Profile {
  id                    String                     @id @default(uuid())
  account_id            String                     @unique
  image                 String?
  created_at            DateTime                   @default(now())
  updated_at            DateTime                   @updatedAt
  fullname              String?
  number_phone          String?
  agenda                Agenda[]
  attendances           Attendance[]
  account               Accounts                   @relation(fields: [account_id], references: [id])
  member_profile_comity Member_Profiles_Comities[]

  @@map("member_profile")
}
