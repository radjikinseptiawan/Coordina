model Accounts {
  id                     String                     @id @default(uuid())
  email                  String                     @unique
  password               String
  username               String
  profileImage           String?
  created_at             DateTime                   @default(now())
  updated_at             DateTime                   @updatedAt
  refresh_token          String?                    @unique
  userProfile            User_Profile?
  memberProfilesComities Member_Profiles_Comities[]

  @@map("accounts")
}

model Accounts_Otp {
  id         String    @id @default(uuid())
  otp_code   Int
  email      String
  isUsed     Boolean   @default(false)
  used_at    DateTime?
  expires_at DateTime  @updatedAt
  created_at DateTime  @default(now())

  @@map("accounts_otp")
}

model User_Profile {
  id                    String                     @id @default(uuid())
  account_id            String                     @unique
  image                 String?
  created_at            DateTime                   @default(now())
  updated_at            DateTime                   @updatedAt
  fullname              String?
  account               Accounts                   @relation(fields: [account_id], references: [id])
  member_profile_comity Member_Profiles_Comities[]

  @@map("member_profile")
}
